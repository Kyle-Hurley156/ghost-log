{
	"appId": "com.ghostlog.app",
	"appName": "GhostLog",
	"webDir": "dist",
	"plugins": {
		"SplashScreen": {
			"launchAutoHide": true,
			"launchShowDuration": 2000,
			"backgroundColor": "#000000",
			"showSpinner": false
		},
		"StatusBar": {
			"style": "DARK",
			"backgroundColor": "#000000"
		},
		"GoogleAuth": {
			"scopes": [
				"profile",
				"email"
			],
			"grantOfflineAccess": true
		}
	},
	"ios": {
		"backgroundColor": "#000000"
	},
	"android": {
		"backgroundColor": "#000000"
	}
}
